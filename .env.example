# 向量模型的本地缓存目录（按机器而异，换电脑改这里即可）
MODEL_DIR=E:\models

# 大模型接口（RAG 生成环节用）
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash

# 在线向量模型（embed_online.py 用）
# 纯文本 embedding 接入点（endpoint 类型），base_url 用 /api/v3
ARK_API_KEY=your-ark-key-here
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# endpoint 类型接入点路径（注意带 /multimodal 后缀）
ARK_EMBED_ENDPOINT=/embeddings/multimodal
EMBED_MODEL=ep-20260625110146-r8f6b
# 可选：指定返回维度，不传则模型默认
# EMBED_DIMENSIONS=1024
